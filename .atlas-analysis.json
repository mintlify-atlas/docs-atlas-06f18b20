  "keyFeatures": [
    "Agent-team orchestration pattern with delegate-only coordinator",
    "9 specialized sub-agents for structured feature development",
    "Pluggable artifact storage (engram, openspec, none)",
    "Zero dependencies - pure Markdown skills",
    "DAG-based phase orchestration with parallel execution",
    "Delta specs for incremental requirements changes",
    "TDD workflow support in implementer v2.0",
    "Real test execution and spec compliance verification in verifier v2.0",
    "Works with Claude Code, OpenCode, Cursor, Gemini CLI, VS Code Copilot, and more"
  ],
  "publicApiSurface": [
    "/sdd-init - Initialize SDD context and detect project stack",
    "/sdd-explore <topic> - Investigate ideas without creating files",
    "/sdd-new <name> - Start a new change with exploration and proposal",
    "/sdd-continue - Run next dependency-ready phase via sub-agents",
    "/sdd-ff <name> - Fast-forward planning (proposal → specs → design → tasks)",
    "/sdd-apply - Implement tasks in batches with progress tracking",
    "/sdd-verify - Validate implementation against specs",
    "/sdd-archive - Close change and merge delta specs",
    "sdd-init/SKILL.md - Init sub-agent skill",
    "sdd-explore/SKILL.md - Explorer sub-agent skill",
    "sdd-propose/SKILL.md - Proposer sub-agent skill",
    "sdd-spec/SKILL.md - Spec Writer sub-agent skill",
    "sdd-design/SKILL.md - Designer sub-agent skill",
    "sdd-tasks/SKILL.md - Task Planner sub-agent skill",
    "sdd-apply/SKILL.md - Implementer sub-agent skill (v2.0 with TDD)",
    "sdd-verify/SKILL.md - Verifier sub-agent skill (v2.0 with real test execution)",
    "sdd-archive/SKILL.md - Archiver sub-agent skill"
  ]
